# Network: mainnet or fuji (AVAXT testnet)
AVAX_NETWORK=mainnet

# Persistent chain data (use separate dirs per network)
DATA_DIR=./data

# Docker container name
CONTAINER_NAME=avax-mainnet

# Host ports (RPC bound to localhost in compose)
HTTP_PORT=9650
P2P_PORT=9651

# Download and extract a snapshot when DATA_DIR has no chain db
SNAPSHOT_RESTORE=true

# Optional: override auto-resolved snapshot URL (see https://publicnode.com/snapshots)
# SNAPSHOT_URL=

# Optional: snapshot type resolved from PublicNode (pruned | archive)
# SNAPSHOT_VARIANT=pruned

# Optional: tar extract target inside container (default: /root/.avalanchego/db)
# SNAPSHOT_EXTRACT_DIR=

# Fuji example:
# AVAX_NETWORK=fuji
# DATA_DIR=./data-fuji
# CONTAINER_NAME=avax-fuji
